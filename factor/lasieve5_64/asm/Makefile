# -----------------------------------------------------------------------------
# factor/lasieve5_64/asm/Makefile
#
# Builds the assembly sieve libraries:
#   liblasieve.a           — core sieve objects
#   liblasieveI11.a  \
#   liblasieveI12.a   |
#   liblasieveI13.a   |    — I-parameterised sieve variants (I=11..16)
#   liblasieveI14.a   |
#   liblasieveI15.a   |
#   liblasieveI16.a  /
#
# Normally invoked by the parent Makefile (factor/lasieve5_64/Makefile) via
# the asm/%: force delegation rule, which passes CC, GMP_INCDIR, DETECTED_OS,
# and any AVX512 flags through ASM_FLAGS.
#
# Can also be invoked directly for standalone asm builds:
#   make all
#   make all AVX512_LASCHED=1
#   make all GMP_INCDIR=/path/to/gmp/include
#   make clean
#
# OS detection for m4:
#   ls-defs.asm contains three OS define lines (windows, osx, linux).
#   At build time a patched copy (ls-defs-os.asm) is generated with all
#   three commented out, and the correct one is injected via M4_OS_DEF
#   on the m4 command line.  ls-defs.asm is never modified.
#
# Note: if.h (referenced as ../if.h) and the generated .h files (siever-config.h,
# lasched.h, medsched.h) must already exist in the repository.  They were
# previously generated by CTANGLE from .w source files; CTANGLE is no longer
# required since the generated files are committed directly.
# -----------------------------------------------------------------------------


# --- Standalone fallbacks (overridden when called from parent Makefile) ------
CC         ?= gcc
GMP_INCDIR ?= /usr/include

ifndef DETECTED_OS
    ifeq ($(OS),Windows_NT)
        DETECTED_OS := Windows
    else
        DETECTED_OS := $(shell uname -s)
    endif
endif


# --- CFLAGS: platform selection ----------------------------------------------
#
# clang and gcc use identical flags on Linux; the compiler is chosen via CC.
# Windows/MinGW requires -DULL_NO_UL and -DBITS_PER_GMP_ULONG=32 to reconcile
# GMP's 32-bit ulong (as configured by its ./configure on Windows) with
# lasieve's 64-bit ulong assumption in siever-config.h.
#
ifeq ($(DETECTED_OS),Windows)
    CFLAGS = -m64 -g -Ofast -march=native -I. -I$(GMP_INCDIR) \
             -DULL_NO_UL -DBITS_PER_GMP_ULONG=32 -fcommon
else
    CFLAGS = -m64 -g -Ofast -march=native -I. -I$(GMP_INCDIR) -fcommon
endif

ifeq ($(DEBUG),1)
    CFLAGS := $(filter-out -Ofast -march=native,$(CFLAGS))
    CFLAGS += -O0
endif


# --- AVX-512 feature flags ---------------------------------------------------
# These are forwarded from the parent Makefile via ASM_FLAGS.
# AVX512_LASCHED and AVX512_TD are the only asm-level AVX-512 switches.

ifeq ($(AVX512_LASCHED),1)
    CFLAGS += -DAVX512_LASCHED
endif

ifeq ($(AVX512_TD),1)
    CFLAGS += -DAVX512_TD
endif


# --- m4 OS definition --------------------------------------------------------
#
# ls-defs.asm contains three OS-selection lines near the top:
#
#   dnl define(windows,1)dnl
#   dnl define(osx,1)dnl
#   define(linux,1)dnl
#
# Rather than editing that file per platform, we generate ls-defs-os.asm at
# build time with ALL three lines commented out (dnl prefix), then inject the
# correct one via M4_OS_DEF on the m4 command line.  This leaves the original
# ls-defs.asm untouched and works correctly for all three platforms.
#
ifeq ($(DETECTED_OS),Windows)
    M4_OS_DEF := -Dwindows=1
else ifeq ($(DETECTED_OS),Darwin)
    M4_OS_DEF := -Dosx=1
else
    M4_OS_DEF := -Dlinux=1
endif

# Generate ls-defs-os.asm: a copy of ls-defs.asm with all three OS define()
# calls silenced.  The sed expressions only match bare define() at line start
# (no leading dnl), so running this against an already-patched file is safe.
ls-defs-os.asm: ls-defs.asm
	sed \
	    -e 's/^define(windows,1)/dnl define(windows,1)/' \
	    -e 's/^define(osx,1)/dnl define(osx,1)/'         \
	    -e 's/^define(linux,1)/dnl define(linux,1)/'     \
	    $< > $@


# --- Assembly preprocessing pipeline -----------------------------------------
#
# .asm → .S  (m4 macro expansion)
# .S   → .o  (compiler assembles the expanded file)
# .s   → .o  (compiler assembles pre-generated .s files)
#
# All m4 invocations use ls-defs-os.asm (not ls-defs.asm directly) so the
# OS define comes from M4_OS_DEF rather than the file.  $< in the %.S rule
# refers to the .asm source; ls-defs-os.asm is listed first so m4 sees the
# macro definitions before the source that uses them.
#
%.S: %.asm ls-defs-os.asm
	m4 -g $(M4_OS_DEF) -Dn_i_bits=0 ls-defs-os.asm $< > $@

%.o: %.S
	$(CC) $(CFLAGS) -c $^

%.o: %.s
	$(CC) $(CFLAGS) -c $^

# Retain intermediate .s and .S files so incremental rebuilds don't re-run m4.
.SECONDARY: *.s *.S


# --- Phony targets -----------------------------------------------------------
.PHONY: all bup clean


# --- Default goal ------------------------------------------------------------
all: liblasieve.a \
     liblasieveI11.a liblasieveI12.a liblasieveI13.a \
     liblasieveI14.a liblasieveI15.a liblasieveI16.a


# --- Explicit header dependencies --------------------------------------------
gcd32.o mpqs.o psp.o MMX-TD.o lasched.o: siever-config.h


# --- liblasieve.a (core sieve objects) ---------------------------------------
liblasieve.a: \
	gcd32.o psp.o pt64.o modinv1000.o ri-aux.o mpz-trialdiv.o \
	asm_64bit.o \
	modinv1000b.o schedsieve.o mpz-td.o MMX-TD.o MMX-TD1.o MMX-TD2.o \
	tdsieve-from-sched.o lasieve-asmprepn.o zeit.o asm-zeit.o \
	lasieve-asmprepn64.o lasieve-asmprepn2_64.o translate.o rescale.o \
	mpqs_td.o invtab.o mpqs_sieve.o mpqs_eval.o mpqs_sieveinit.o \
	mpqs_nextpol.o mpqs_gauss.o lasieve-asmprepn2.o \
	noasm64.o basemath.o montgomery_mul.o asm_arith64.o asm_arith128.o \
	asm_arith192.o mpqs3_sieve.o mpqs3_nextpol.o mpqs3_td.o \
	mpqs3_gauss.o
	ar rcs $@ $^


# --- I-parameterised .s generation rules ------------------------------------
#
# Each rule generates a specialised assembly .s file for a given I value.
# The stem % is the I value (e.g. 11..16); n_i_bits = I - 1.
# All rules use ls-defs-os.asm and $(M4_OS_DEF); $^ expands to
# "ls-defs-os.asm <source>.asm" which is the correct order for m4.
#
lasched0I%.s: ls-defs-os.asm lasched0.asm
	m4 -g $(M4_OS_DEF) -Dn_i_bits=`expr $* - 1` $^ > $@

lasched1I%.s: ls-defs-os.asm lasched1.asm
	m4 -g $(M4_OS_DEF) -Dn_i_bits=`expr $* - 1` -Dot=1 $^ > $@

lasched2I%.s: ls-defs-os.asm lasched1.asm
	m4 -g $(M4_OS_DEF) -Dn_i_bits=`expr $* - 1` -Dot=2 $^ > $@

lasched3I%.s: ls-defs-os.asm lasched1.asm
	m4 -g $(M4_OS_DEF) -Dn_i_bits=`expr $* - 1` -Dot=3 $^ > $@

lasched0ntI%.s: ls-defs-os.asm lasched0.asm
	m4 -g $(M4_OS_DEF) -Dn_i_bits=`expr $* - 1` -Dnt_sched=1 $^ > $@

lasched1ntI%.s: ls-defs-os.asm lasched1.asm
	m4 -g $(M4_OS_DEF) -Dn_i_bits=`expr $* - 1` -Dot=1 -Dnt_sched=1 $^ > $@

lasched2ntI%.s: ls-defs-os.asm lasched1.asm
	m4 -g $(M4_OS_DEF) -Dn_i_bits=`expr $* - 1` -Dot=2 -Dnt_sched=1 $^ > $@

lasched3ntI%.s: ls-defs-os.asm lasched1.asm
	m4 -g $(M4_OS_DEF) -Dn_i_bits=`expr $* - 1` -Dot=3 -Dnt_sched=1 $^ > $@

medsched0I%.s: ls-defs-os.asm medsched0.asm
	m4 -g $(M4_OS_DEF) -Dn_i_bits=`expr $* - 1` $^ > $@


# --- I-parameterised .o compilation rules ------------------------------------
# ../if.h resolves to factor/lasieve5_64/if.h
laschedI%.o: lasched.c lasched.h siever-config.h ../if.h
	$(CC) $(CFLAGS) -DI_bits=$* -c -o $@ $<

medschedI%.o: medsched.c medsched.h siever-config.h ../if.h
	$(CC) $(CFLAGS) -DI_bits=$* -c -o $@ $<


# --- I-parameterised sieve line .s generation rules -------------------------
slinieI%.s: ls-defs-os.asm slinieG.asm
	m4 -g $(M4_OS_DEF) -Dn_i_bits=`expr $* - 1` $^ > $@

slinie3I%.s: ls-defs-os.asm slinie3A.asm
	m4 -g $(M4_OS_DEF) -Dn_i_bits=`expr $* - 1` $^ > $@

slinie2I%.s: ls-defs-os.asm slinie2A.asm
	m4 -g $(M4_OS_DEF) -Dn_i_bits=`expr $* - 1` $^ > $@

slinie1I%.s: ls-defs-os.asm slinie1A.asm
	m4 -g $(M4_OS_DEF) -Dn_i_bits=`expr $* - 1` $^ > $@

tdslinieI%.s: ls-defs-os.asm tdslinie.asm
	m4 -g $(M4_OS_DEF) -Dn_i_bits=`expr $* - 1` $^ > $@

tdslinie1I%.s: ls-defs-os.asm tdslinie1.asm
	m4 -g $(M4_OS_DEF) -Dn_i_bits=`expr $* - 1` $^ > $@

tdslinie2I%.s: ls-defs-os.asm tdslinie2.asm
	m4 -g $(M4_OS_DEF) -Dn_i_bits=`expr $* - 1` $^ > $@

tdslinie3I%.s: ls-defs-os.asm tdslinie3.asm
	m4 -g $(M4_OS_DEF) -Dn_i_bits=`expr $* - 1` $^ > $@

search0I%.s: ls-defs-os.asm search0.asm
	m4 -g $(M4_OS_DEF) -Dn_i_bits=`expr $* - 1` $^ > $@


# --- liblasieveI%.a (I-parameterised sieve library) -------------------------
liblasieveI%.a: \
	laschedI%.o lasched0I%.o lasched1I%.o lasched2I%.o \
	lasched3I%.o lasched0ntI%.o lasched1ntI%.o lasched2ntI%.o \
	lasched3ntI%.o medschedI%.o medsched0I%.o search0I%.o \
	slinieI%.o slinie3I%.o slinie2I%.o slinie1I%.o \
	tdslinieI%.o tdslinie1I%.o tdslinie2I%.o tdslinie3I%.o
	ar rcs $@ $^


# --- Utility -----------------------------------------------------------------
bup:
	@echo $(SRCFILES)

clean:
	-rm -f *.o *.a *.s *.S ls-defs-os.asm
